# ============================================================
# EcoCloud Edge — Variables de entorno (EJEMPLO SIN SECRETOS)
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el archivo .env a Git.
# ============================================================

# ── Red del clúster ─────────────────────────────────────────
NODE1_IP=192.168.1.70
NODE2_IP=192.168.1.71
NODE3_IP=192.168.1.72
NODE4_IP=192.168.1.73
METALLB_POOL_START=192.168.1.80
METALLB_POOL_END=192.168.1.90

# ── k3s ─────────────────────────────────────────────────────
K3S_TOKEN=CAMBIA_ESTO_POR_EL_TOKEN_REAL

# ── MariaDB ─────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=CAMBIA_ESTO
MYSQL_DATABASE=nextcloud
MYSQL_USER=nextcloud_user
MYSQL_PASSWORD=CAMBIA_ESTO

# ── Nextcloud ───────────────────────────────────────────────
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=CAMBIA_ESTO
NEXTCLOUD_DOMAIN=nubes.ecocloud.local

# ── LLDAP ───────────────────────────────────────────────────
LLDAP_LDAP_USER_PASS=CAMBIA_ESTO
LLDAP_JWT_SECRET=CAMBIA_ESTO_POR_CADENA_ALEATORIA_LARGA
LLDAP_LDAP_BASE_DN=dc=ecocloud,dc=local

# ── Grafana ─────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=CAMBIA_ESTO
GRAFANA_DOMAIN=monitor.ecocloud.local

# ── Ansible SSH ─────────────────────────────────────────────
ANSIBLE_USER=admin
ANSIBLE_SSH_KEY_PATH=~/.ssh/id_ed25519
