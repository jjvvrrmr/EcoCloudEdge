# ansible/inventory.ini.example
# Copia como inventory.ini y ajusta IPs/usuario SSH
# Este archivo SÍ puede subirse a Git (sin contraseñas)

[master]
node1 ansible_host=192.168.1.70 ansible_user=admin

[workers]
node2 ansible_host=192.168.1.71 ansible_user=admin
node3 ansible_host=192.168.1.72 ansible_user=admin
node4 ansible_host=192.168.1.73 ansible_user=admin

[k3s_cluster:children]
master
workers

[all:vars]
ansible_ssh_private_key_file=~/.ssh/id_ed25519
ansible_become=true
ansible_become_method=sudo
